# Copy this file to `internal/aliyun/testdata/aliyun-live.env` and fill in real values.
# The real `aliyun-live.env` file is ignored by git and used only for local live tests.
# These tests make real Aliyun API calls, and the CDN binding test can update a live domain's certificate binding.

ALIYUN_REGION=cn-hangzhou
ALIYUN_ACCESS_KEY_ID=<your-access-key-id>
ALIYUN_ACCESS_KEY_SECRET=<your-access-key-secret>
ALIYUN_CAS_ENDPOINT=https://cas.aliyuncs.com
ALIYUN_CDN_ENDPOINT=https://cdn.aliyuncs.com

# Existing uploaded certificate fingerprint for lookup testing.
ALIYUN_LIVE_CERT_FINGERPRINT=<existing-certificate-fingerprint>

# Optional: used by the live CDN binding test.
ALIYUN_LIVE_CERT_ID=<existing-certificate-id>
ALIYUN_LIVE_CDN_DOMAIN=<cdn-domain-to-update>
